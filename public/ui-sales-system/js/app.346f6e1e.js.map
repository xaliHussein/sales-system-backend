<template>
  <v-col cols="12" class="pt-1 pt-md-2">
    <v-card class="chart-card" width="100%">
      <v-card-title class="chart-title text-center">
        {{ chartTitle }}
      </v-card-title>
      <div class="chart-wrapper">
        <BarChart
          :data="chart_data"
          :options="chartOptions"
        />
      </div>
    </v-card>
  </v-col>
</template>

<script setup>
import { useDisplay } from "vuetify";
import { computed } from "vue";

defineProps({
  chart_data: {
    type: Object,
    required: true,
    default: null,
  },
  chartTitle: {
    type: String,
    default: "احصائات المبيعات السنوية",
  },
});

const { mobile } = useDisplay();
let delayed = false;

const chartOptions = computed(() => ({
  responsive: true,
  maintainAspectRatio: true,
  aspectRatio: mobile.value ? 1.4 : 2.5,
  interaction: {
    intersect: false,
    axis: "x",
  },
  stacked: false,
  plugins: {
    legend: {
      labels: {
        font: {
          size: mobile.value ? 11 : 14,
          family: "'Cairo', sans-serif",
          weight: "bold",
        },
        boxWidth: mobile.value ? 12 : 40,
        padding: mobile.value ? 8 : 10,
      },
    },
  },
  scales: {
    x: {
      ticks: {
        font: {
          size: mobile.value ? 10 : 14,
          family: "'Cairo', sans-serif",
          weight: "bold",
        },
        maxRotation: mobile.value ? 45 : 0,
      },
    },
    y: {
      ticks: {
        font: {
          size: mobile.value ? 9 : 14,
          family: "'Cairo', sans-serif",
          weight: "bold",
        },
        callback: function(value) {
          if (mobile.value && value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
          if (mobile.value && value >= 1000) return (value / 1000).toFixed(0) + 'K';
          return value.toLocaleString();
        },
      },
    },
  },
  animation: {
    onComplete: () => { delayed = true; },
    delay: (context) => {
      let delay = 0;
      if (context.type === "data" && context.mode === "default" && !delayed) {
        delay = context.dataIndex * 200 + context.datasetIndex * 100;
      }
      return delay;
    },
  },
}));

</script>

<style scoped>
.chart-card {
  border-radius: 20px !important;
  border: 1px solid rgba(98, 79, 198, 0.06);
  box-shadow: none !important;
  overflow: hidden;
}
.chart-title {
  font-weight: 700;
  font-size: 1.05rem;
  color: #1a1a2e;
  padding: 16px 16px 8px;
}
.chart-wrapper {
  padding: 8px 12px 16px;
}

@media (max-width: 600px) {
  .chart-title {
    font-size: 0.9rem;
    padding: 12px 12px 4px;
  }
  .chart-wrapper {
    padding: 4px 6px 12px;
  }
  .chart-card {
    border-radius: 16px !important;
  }
}
</style>
