<template>
  <v-col col="12" sm="12" md="12" lg="12" class="pt-2">
    <v-card class="card" width="100%" :height="650">
      <v-card-title class="d-flex justify-center pb-0 mb-0"
        >احصائات المبيعات السنوية
      </v-card-title>

      <BarChart
        :data="chart_data"
        :options="options"
        :width="400"
        :height="height"
      />
    </v-card>
  </v-col>
</template>
<script setup>
import { useDisplay } from "vuetify";
import { computed } from "vue";

defineProps({
  chart_data: {
    type: Object,
    required: true,
    default: null,
  },
});

const { name: breakpointName } = useDisplay();
let delayed = false;
const options = {
  responsive: true,
  interaction: {
    intersect: false,
    axis: "x",
  },
  stacked: false,
  plugins: {
    legend: {
      labels: {
        font: {
          size: 14,
          family: "'Cairo', sans-serif",
          weight: "bold",
        },
      },
    },
  },

  
  // font the X & Y axes
  scales: {
    x: {
      ticks: {
        font: {
          size: 14,
          family: "'Cairo', sans-serif",
          weight: "bold",
        },
      },
    },
    y: {
      ticks: {
        font: {
          size: 14,
          family: "'Cairo', sans-serif",
          weight: "bold",
        },
      },
    },
  },

  // animation
  animation: {
    onComplete: () => {
      delayed = true;
    },
    delay: (context) => {
      let delay = 0;
      if (context.type === "data" && context.mode === "default" && !delayed) {
        delay = context.dataIndex * 200 + context.datasetIndex * 100;
      }
      return delay;
    },
  },
};

const height = computed(() => {
  switch (breakpointName.value) {
    case "xs":
      return 320;
    case "sm":
      return 190;
    case "md":
      return 200;
    case "lg":
      return 150;
    case "xl":
      return 150;
    default:
      return 150;
  }
});
</script>

<style scoped>
.card {
  border-radius: 25px !important;
  box-shadow: 0px 0px 0px 0px !important;
}
</style>
